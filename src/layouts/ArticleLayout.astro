---
import SEOHead from '@/components/SEOHead.astro';
import SchemaOrg from '@/components/SchemaOrg.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import FAQ from '@/components/FAQ.astro';
import { getAuthor } from '@/data/authors';
import { getLang, localizedUrl, t, getDateLocale } from '@/utils/i18n';
import '@/styles/global.css';

export interface Props {
  title: string;
  description: string;
  date: Date | string;
  updatedDate?: Date | string;
  author: string;
  category: string;
  tags: string[];
  slug: string;
  faq?: Array<{ question: string; answer: string }>;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  readingTime?: number;
}

const {
  title,
  description,
  date,
  updatedDate,
  author: authorId,
  category,
  tags,
  slug,
  faq,
  headings = [],
  readingTime,
} = Astro.props;

const tocHeadings = headings.filter((h) => h.depth === 2);

const lang = getLang(Astro.url);
const author = getAuthor(authorId);
const categorySlug = category.toLowerCase().replace(/\s+/g, '-').normalize('NFD').replace(/[\u0300-\u036f]/g, '');
const categoryPrefix = t(lang, 'categoryPrefix');

function parseDate(val: Date | string | undefined): Date | undefined {
  if (!val) return undefined;
  if (val instanceof Date && !isNaN(val.getTime())) return val;
  const d = new Date(String(val));
  return isNaN(d.getTime()) ? new Date() : d;
}

const safeDate = parseDate(date) ?? new Date();
const safeUpdatedDate = parseDate(updatedDate);

const breadcrumbItems = [
  { name: 'Blog', url: localizedUrl('/blog/', lang) },
  { name: category, url: localizedUrl(`/${categoryPrefix}/${categorySlug}/`, lang) },
  { name: title, url: localizedUrl(`/blog/${slug}/`, lang) },
];

const dateLocale = getDateLocale(lang);
const formattedDate = safeDate.toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = safeUpdatedDate?.toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<!doctype html>
<html lang={lang}>
  <head>
    <SEOHead
      title={title}
      description={description}
      ogType="article"
      publishedDate={safeDate}
      modifiedDate={safeUpdatedDate}
      author={author.name}
    />
    <SchemaOrg
      type="article"
      title={title}
      description={description}
      url={Astro.url.href}
      datePublished={safeDate}
      dateModified={safeUpdatedDate ?? safeDate}
      authorId={authorId}
      category={category}
      tags={tags}
    />
    {faq && faq.length > 0 && (
      <SchemaOrg type="faq" faq={faq} />
    )}
  </head>
  <body>
    <Header />
    <main id="main-content">
      <article class="article">
        <div class="container">
          <Breadcrumb items={breadcrumbItems} />

          <header class="article__header">
            <a href={localizedUrl(`/${categoryPrefix}/${categorySlug}/`, lang)} class="tag article__category">{category}</a>
            <h1 class="article__title">{title}</h1>
            <p class="article__description">{description}</p>

            <div class="article__byline">
              {author.avatar && (
                <img
                  class="article__byline-avatar"
                  src={author.avatar}
                  alt={author.name}
                  width="32"
                  height="32"
                  loading="lazy"
                />
              )}
              <span class="article__byline-author">{author.name}</span>
              <span class="article__byline-dot" aria-hidden="true"></span>
              <time datetime={safeDate.toISOString()}>{formattedDate}</time>
              {readingTime && (
                <>
                  <span class="article__byline-dot" aria-hidden="true"></span>
                  <span>{readingTime} {t(lang, 'readingTime')}</span>
                </>
              )}
              {safeUpdatedDate && (
                <span class="article__updated">
                  ({t(lang, 'updatedOn')} <time datetime={safeUpdatedDate.toISOString()}>{formattedUpdatedDate}</time>)
                </span>
              )}
            </div>
          </header>

          {tocHeadings.length > 0 && (
            <details class="toc">
              <summary class="toc__summary">
                <span class="toc__title">{t(lang, 'tableOfContents')}</span>
                <svg class="toc__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </summary>
              <nav class="toc__nav" aria-label={t(lang, 'tableOfContents')}>
                <ol class="toc__list">
                  {tocHeadings.map((h) => (
                    <li><a href={`#${h.slug}`}>{h.text}</a></li>
                  ))}
                </ol>
              </nav>
            </details>
          )}

          <div class="prose">
            <slot />
          </div>

          {faq && faq.length > 0 && (
            <FAQ faq={faq} />
          )}

          <footer class="article__footer">
            <div class="article__author">
              {author.avatar && (
                author.url ? (
                  <a href={author.url} target="_blank" rel="noopener" class="article__author-avatar-link">
                    <img
                      class="article__author-avatar"
                      src={author.avatar}
                      alt={author.name}
                      width="72"
                      height="72"
                      loading="lazy"
                    />
                  </a>
                ) : (
                  <img
                    class="article__author-avatar"
                    src={author.avatar}
                    alt={author.name}
                    width="72"
                    height="72"
                    loading="lazy"
                  />
                )
              )}
              <div class="article__author-info">
                <span class="article__author-label">{t(lang, 'publishedBy')}</span>
                <strong class="article__author-name">
                  {author.url ? (
                    <a href={author.url} target="_blank" rel="noopener">{author.name}</a>
                  ) : (
                    author.name
                  )}
                </strong>
                <span class="article__author-role">{author.role}</span>
                {author.sameAs && author.sameAs.length > 0 && (
                  <span class="article__author-socials">
                    {author.sameAs.map((link) => (
                      <a href={link} target="_blank" rel="noopener me" class="article__author-social">
                        {link.includes('linkedin') ? 'LinkedIn' : link.replace(/^https?:\/\/(www\.)?/, '').replace(/\/$/, '')}
                      </a>
                    ))}
                  </span>
                )}
              </div>
            </div>

            {tags.length > 0 && (
              <div class="article__tags">
                <span class="article__tags-label">{t(lang, 'tags')}</span>
                <div class="article__tags-list">
                  {tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            )}
          </footer>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
  .article {
    padding: var(--spacing-xl) 0 var(--spacing-4xl);
  }

  .article__header {
    max-width: var(--max-width-content);
    margin: 0 auto var(--spacing-2xl);
    text-align: center;
  }

  .article__category {
    display: inline-block;
    margin-bottom: var(--spacing-lg);
  }

  .article__title {
    font-size: var(--font-size-4xl);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: var(--spacing-lg);
  }

  .article__description {
    font-size: var(--font-size-xl);
    color: var(--color-gray-600);
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto;
  }

  .article__byline {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-lg);
    font-size: var(--font-size-sm);
    color: var(--color-gray-500);
  }

  .article__byline-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }

  .article__byline-author {
    font-weight: 600;
    color: var(--color-gray-800);
  }

  .article__byline-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background-color: var(--color-gray-300);
  }

  .article__updated {
    font-style: italic;
    color: var(--color-gray-400);
  }

  /* --- Table of contents (collapsible) --- */
  .toc {
    max-width: var(--max-width-content);
    margin: var(--spacing-2xl) auto 0;
    border: 1px solid var(--color-gray-200);
    border-radius: var(--border-radius-lg);
    background-color: var(--color-gray-50);
    overflow: hidden;
  }

  .toc__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-sm);
    padding: var(--spacing-md) var(--spacing-lg);
    cursor: pointer;
    list-style: none;
    font-weight: 700;
    color: var(--color-gray-900);
    user-select: none;
  }

  .toc__summary::-webkit-details-marker {
    display: none;
  }

  .toc__title {
    font-size: var(--font-size-base);
  }

  .toc__chevron {
    color: var(--color-gray-500);
    transition: transform var(--transition-base);
    flex-shrink: 0;
  }

  .toc[open] .toc__chevron {
    transform: rotate(180deg);
  }

  .toc__summary:hover .toc__title {
    color: var(--color-primary);
  }

  .toc__nav {
    padding: 0 var(--spacing-lg) var(--spacing-md);
    border-top: 1px solid var(--color-gray-200);
  }

  .toc__list {
    counter-reset: toc;
    list-style: none;
    padding: 0;
    margin: var(--spacing-md) 0 0;
    display: grid;
    gap: var(--spacing-xs);
  }

  .toc__list li {
    counter-increment: toc;
  }

  .toc__list a {
    display: flex;
    gap: var(--spacing-sm);
    padding: var(--spacing-xs) 0;
    color: var(--color-gray-700);
    text-decoration: none;
    font-size: var(--font-size-sm);
    line-height: 1.5;
  }

  .toc__list a::before {
    content: counter(toc, decimal-leading-zero);
    color: var(--color-cyan);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .toc__list a:hover {
    color: var(--color-primary);
  }

  .article__footer {
    max-width: var(--max-width-content);
    margin: var(--spacing-3xl) auto 0;
    padding-top: var(--spacing-2xl);
    border-top: 1px solid var(--color-gray-200);
  }

  .article__author {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .article__author-avatar-link {
    flex-shrink: 0;
    display: block;
  }

  .article__author-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }

  .article__author-info {
    display: flex;
    flex-direction: column;
  }

  .article__author-socials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-xs);
  }

  .article__author-social {
    font-size: var(--font-size-sm);
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .article__author-social:hover {
    text-decoration: underline;
  }

  .article__author-label {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-400);
    margin-bottom: var(--spacing-xs);
  }

  .article__author-name {
    font-size: var(--font-size-lg);
  }

  .article__author-name a {
    color: var(--color-gray-900);
    text-decoration: none;
  }

  .article__author-name a:hover {
    color: var(--color-primary);
  }

  .article__author-role {
    font-size: var(--font-size-sm);
    color: var(--color-gray-500);
  }

  .article__tags {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .article__tags-label {
    font-size: var(--font-size-sm);
    color: var(--color-gray-500);
    font-weight: 500;
  }

  .article__tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  @media (max-width: 768px) {
    .article__title {
      font-size: var(--font-size-3xl);
    }

    .article__description {
      font-size: var(--font-size-lg);
    }
  }
</style>
